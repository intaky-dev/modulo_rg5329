<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_tax_form_rg5329" model="ir.ui.view">
            <field name="name">account.tax.form.rg5329</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='description']" position="after">
                    <group string="RG 5329" invisible="type_tax_use != 'sale'">
                        <field name="is_rg5329_perception"/>
                    </group>
                </xpath>
            </field>
        </record>
        <record id="account_tax_group_form_rg5329" model="ir.ui.view">
            <field name="name">account.tax.group.form.rg5329</field>
            <field name="model">account.tax.group</field>
            <field name="inherit_id" ref="account.view_tax_group_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="l10n_ar_tribute_afip_code" readonly="False"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
